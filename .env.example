# ==========================================
# RouteReserve Environment Variables Setup
# ==========================================

# ----------------------------
# Backend Configuration
# ----------------------------
# PostgreSQL Connection String (used by Prisma)
# Replace credentials below with your actual Postgres server values
DATABASE_URL="postgresql://db_user:db_password@localhost:5432/routereserve_db?schema=public"

# JWT Token Verification Secret Key (Use a strong alphanumeric secret)
JWT_SECRET="your-jwt-alphanumeric-secret-key-goes-here"

# Port on which the NestJS backend API listens
PORT=5000

# ----------------------------
# Frontend Configuration
# ----------------------------
# API Endpoint URL (points to local NestJS or deployed cloud server)
NEXT_PUBLIC_API_URL="http://localhost:5000"
